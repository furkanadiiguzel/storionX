{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=3306;Database=ev_migration;User=root;Password=password;"
  },
  "StorionXClient": {
    "BaseUrl": "http://localhost:8081",
    "MaxRetryAttempts": 5,
    "BaseDelayMs": 500,
    "CircuitBreakerFailureRatio": 0.5,
    "CircuitBreakerSamplingSeconds": 30
  },
  "FilePartReader": {
    "BlobDir": "/data/blobs"
  },
  "JsonIdentityMap": {
    "MappingFile": "/data/mapping.json"
  },
  "PolicyOptions": {
    "LegalHoldPolicy": "Retain"
  },
  "Transformer": {
    "ToolVersion": "1.0.0"
  },
  "Orchestrator": {
    "MaxParallelWorkers": 8,
    "CheckpointEveryN": 100,
    "DryRun": false
  },
  "AllowedHosts": "*"
}
