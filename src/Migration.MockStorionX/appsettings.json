{
  "RateLimit": {
    "RequestsPerSecond": 20,
    "BurstCapacity": 40
  },
  "Chaos": {
    "Transient503Percent": 5,
    "RandomSeed": null
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": { "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog" }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
